[
  {
    "Name": "While Bot is Running",
    "Icon": "🔁",
    "Category": "Logic",
    "Description": "The primary loop for any bot. Keeps the script alive until you hit STOP.",
    "Template": "while bot.is_running:\n{selection}\n    bot.wait(0.05)",
    "Parameters": [],
    "RequiresRegion": false,
    "InsertMode": "wrap"
  },
  {
    "Name": "If/Else Condition",
    "Icon": "🔀",
    "Category": "Logic",
    "Description": "Standard Python if/else conditional block.",
    "Template": "if {condition}:\n{selection}\nelse:\n    pass",
    "Parameters": [
      { "Key": "condition", "Type": "text", "DefaultValue": "True" }
    ],
    "RequiresRegion": false,
    "InsertMode": "wrap"
  },
  {
    "Name": "For Loop",
    "Icon": "🔄",
    "Category": "Logic",
    "Description": "Loop a specific number of times.",
    "Template": "for {var_name} in range({count}):\n{selection}",
    "Parameters": [
      { "Key": "var_name", "Type": "text", "DefaultValue": "i" },
      { "Key": "count", "Type": "number", "DefaultValue": "10" }
    ],
    "RequiresRegion": false,
    "InsertMode": "wrap"
  },
  {
    "Name": "Break",
    "Icon": "🛑",
    "Category": "Logic",
    "Description": "Break out of the current loop.",
    "Template": "break",
    "Parameters": [],
    "RequiresRegion": false,
    "InsertMode": "append"
  },
  {
    "Name": "Continue",
    "Icon": "⏭️",
    "Category": "Logic",
    "Description": "Skip the rest of the current loop iteration.",
    "Template": "continue",
    "Parameters": [],
    "RequiresRegion": false,
    "InsertMode": "append"
  },
  {
    "Name": "Variable Assignment",
    "Icon": "📝",
    "Category": "Logic",
    "Description": "Assign a value to a variable.",
    "Template": "{var_name} = {value}",
    "Parameters": [
      { "Key": "var_name", "Type": "text", "DefaultValue": "my_var" },
      { "Key": "value", "Type": "text", "DefaultValue": "0" }
    ],
    "RequiresRegion": false,
    "InsertMode": "append"
  },
  {
    "Name": "Wait",
    "Icon": "🕒",
    "Category": "Time",
    "Description": "Simple pause in seconds.",
    "Template": "bot.wait({seconds})",
    "Parameters": [
      { "Key": "seconds", "Type": "number", "DefaultValue": "1.0" }
    ],
    "RequiresRegion": false,
    "InsertMode": "append"
  },
  {
    "Name": "Click Region Center",
    "Icon": "🎯",
    "Category": "Mouse",
    "Description": "Clicks the center of a region with optional modifiers.",
    "Template": "bot.click_region(region_index={region_index}, button='{button}', modifiers={modifiers}, human_like={human_like})",
    "Parameters": [
      { "Key": "region_index", "Type": "region", "DefaultValue": "0" },
      { "Key": "button", "Type": "button", "DefaultValue": "left" },
      { "Key": "modifiers", "Type": "modifiers", "DefaultValue": "[]" },
      { "Key": "human_like", "Type": "bool", "DefaultValue": "False" }
    ],
    "RequiresRegion": true,
    "InsertMode": "append"
  },
  {
    "Name": "Click Coordinates",
    "Icon": "👆",
    "Category": "Mouse",
    "Description": "Clicks at the specified screen coordinates with optional modifiers and human-like movement.",
    "Template": "bot.click(x={x}, y={y}, button='{button}', modifiers={modifiers}, human_like={human_like})",
    "Parameters": [
      { "Key": "x", "Type": "number", "DefaultValue": "100" },
      { "Key": "y", "Type": "number", "DefaultValue": "100" },
      { "Key": "button", "Type": "button", "DefaultValue": "left" },
      { "Key": "modifiers", "Type": "modifiers", "DefaultValue": "[]" },
      { "Key": "human_like", "Type": "bool", "DefaultValue": "False" }
    ],
    "RequiresRegion": false,
    "InsertMode": "append"
  },
  {
    "Name": "Find & Click Color",
    "Icon": "🎨",
    "Category": "Vision",
    "Description": "Find a color in a region and click it if found.",
    "Template": "bot.find_and_click_color(hex_color='{hex_color}', region_index={region_index}, tolerance={tolerance}, button='{button}', modifiers={modifiers}, human_like={human_like})",
    "Parameters": [
      { "Key": "hex_color", "Type": "color", "DefaultValue": "#FFFFFF" },
      { "Key": "region_index", "Type": "region", "DefaultValue": "0" },
      { "Key": "tolerance", "Type": "number", "DefaultValue": "10" },
      { "Key": "button", "Type": "button", "DefaultValue": "left" },
      { "Key": "modifiers", "Type": "modifiers", "DefaultValue": "[]" },
      { "Key": "human_like", "Type": "bool", "DefaultValue": "False" }
    ],
    "RequiresRegion": true,
    "InsertMode": "append"
  },
  {
    "Name": "Find & Click Image",
    "Icon": "🖼️",
    "Category": "Vision",
    "Description": "Find an image template on screen and click its center.",
    "Template": "pos = bot.find_image('{image_path}', region_index={region_index}, confidence={confidence})\nif pos:\n    bot.bot.click(pos[0], pos[1], button='{button}', modifiers={modifiers})",
    "Parameters": [
      { "Key": "image_path", "Type": "text", "DefaultValue": "template.png" },
      { "Key": "region_index", "Type": "region", "DefaultValue": "0" },
      { "Key": "confidence", "Type": "number", "DefaultValue": "0.8" },
      { "Key": "button", "Type": "button", "DefaultValue": "left" },
      { "Key": "modifiers", "Type": "modifiers", "DefaultValue": "[]" }
    ],
    "RequiresRegion": true,
    "InsertMode": "append"
  },
  {
    "Name": "Find & Click Text (OCR)",
    "Icon": "🔍",
    "Category": "Vision",
    "Description": "Use OCR to find and click a specific word.",
    "Template": "pos = bot.find_text('{text}', region_index={region_index})\nif pos:\n    bot.bot.click(pos[0], pos[1], button='{button}', modifiers={modifiers})",
    "Parameters": [
      { "Key": "text", "Type": "text", "DefaultValue": "Login" },
      { "Key": "region_index", "Type": "region", "DefaultValue": "0" },
      { "Key": "button", "Type": "button", "DefaultValue": "left" },
      { "Key": "modifiers", "Type": "modifiers", "DefaultValue": "[]" }
    ],
    "RequiresRegion": true,
    "InsertMode": "append"
  },
