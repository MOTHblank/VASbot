<Window x:Class="VASbot.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:services="clr-namespace:VASbot.Gui.UI.Converters"
        xmlns:vm="clr-namespace:VASbot.Gui.UI.ViewModels"
        xmlns:eng="clr-namespace:VASbot.Gui.Engine"
        xmlns:local="clr-namespace:VASbot.Gui.UI.Views"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="VASbot3 Studio" Height="1000" Width="1800"
        Background="#121212">

    <Window.Resources>
        <Style x:Key="ToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <services:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <services:EnumValuesConverter x:Key="EnumValuesConverter" />
        <services:BooleanToRedConverter x:Key="BooleanToRedConverter" />
        <services:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        
        <Style x:Key="StudioHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <!-- Global Hotkeys for Script Control -->
        <KeyBinding Key="F5" Command="{Binding ScriptEditor.RunScriptCommand}"/>
        <KeyBinding Key="F6" Command="{Binding ScriptEditor.StopScriptCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Global Ribbon -->
            <RowDefinition Height="*" />    <!-- Main Workspace -->
            <RowDefinition Height="Auto" /> <!-- Terminal Splitter -->
            <RowDefinition Height="220" MinHeight="100" /> <!-- Console -->
        </Grid.RowDefinitions>

        <!-- 1. GLOBAL RIBBON (Control Plane) -->
        <Border Background="#1e1e1e" BorderBrush="#222" BorderThickness="0,0,0,1" Padding="16,10">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="VASbot3" FontWeight="Black" FontSize="20" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" VerticalAlignment="Center" Margin="0,0,30,0"/>
                    
                    <ui:SimpleStackPanel Orientation="Horizontal" Spacing="12">
                        <ComboBox ItemsSource="{Binding Capture.WindowList}" 
                                  SelectedItem="{Binding Capture.SelectedWindow}"
                                  Width="350" ui:ControlHelper.PlaceholderText="Select Target Window...">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,2">
                                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="12"/>
                                        <TextBlock Text="{Binding ClassName}" FontSize="9" Foreground="#858585"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Content="🔄" Command="{Binding Capture.RefreshWindowsCommand}" ToolTip="Refresh Window List"/>
                        
                        <Separator Margin="10,0" Opacity="0.2"/>
                        
                        <Button Content="▶ RUN" Command="{Binding ScriptEditor.RunScriptCommand}" Background="#27ae60" Foreground="White" FontWeight="Bold" Width="90"/>
                        <Button Content="⏹ STOP" Command="{Binding ScriptEditor.StopScriptCommand}" Background="#c0392b" Foreground="White" FontWeight="Bold" Width="90"/>
                        <Button Content="☠️ KILL" Click="Killswitch_Click" Background="#8b0000" Foreground="White" FontWeight="Bold" Width="70" ToolTip="F12 - Force kill everything"/>
                        <ToggleButton Content="⏺ REC" Command="{Binding ScriptEditor.ToggleRecordingCommand}" 
                                      IsChecked="{Binding ScriptEditor.IsRecording}"
                                      Background="{Binding ScriptEditor.IsRecording, Converter={StaticResource BooleanToRedConverter}}"
                                      Foreground="White" FontWeight="Bold" Width="80"/>

                        <Separator Margin="10,0" Opacity="0.2"/>
                        
                        <ToggleButton Content="🎬 LIVE MIRROR" IsChecked="{Binding Capture.IsReflecting}" 
                                      Background="{Binding Capture.IsReflecting, Converter={StaticResource BooleanToRedConverter}}"
                                      Foreground="White" FontWeight="Bold" Width="130"/>
                        
                        <Button Content="📸 SNAP" Command="{Binding Capture.StaticCaptureCommand}" 
                                Visibility="{Binding Capture.IsReflecting, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}"
                                ToolTip="Take a manual printscreen"/>

                        <Separator Margin="10,0" Opacity="0.2"/>

                        <!-- Color Ribbon Tool -->
                        <StackPanel Orientation="Horizontal">
                            <ToggleButton Content="💧" IsChecked="{Binding Capture.IsEyedropperActive}"
                                          ToolTip="Eyedropper: Pick color from image" Width="40"/>
                            <Border Width="30" Height="24" Background="{Binding Capture.PickedColor}" 
                                    BorderBrush="#444" BorderThickness="1" Margin="8,0,8,0" CornerRadius="2"
                                    ToolTip="Active Pen Color"/>
                            <TextBlock Text="{Binding Capture.PickedColor}" VerticalAlignment="Center" 
                                       Foreground="#858585" FontSize="10" FontFamily="Consolas" Width="60"/>
                        </StackPanel>
                    </ui:SimpleStackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Border CornerRadius="12" Background="#1a1a1a" Padding="15,5">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="Lime" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Status}" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 2. STUDIO WORKSPACE (v2 - Viewport Isolated) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />    <!-- Viewport -->
                <ColumnDefinition Width="Auto" /> <!-- Main Splitter -->
                <ColumnDefinition Width="1.5*" />  <!-- Logic Core (Resizable) -->
            </Grid.ColumnDefinitions>

            <!-- A. VIEWPORT: Isolated & Full Height -->
            <GroupBox Header="VIEWPORT" Margin="8,8,4,8" BorderThickness="1" BorderBrush="#222">
                <Grid Background="#000" ClipToBounds="True">
                    <skia:SKElement x:Name="SkiaElement" 
                                    PaintSurface="SkiaElement_PaintSurface"
                                    MouseDown="SkiaElement_MouseDown"
                                    MouseMove="SkiaElement_MouseMove"
                                    MouseUp="SkiaElement_MouseUp"
                                    MouseWheel="SkiaElement_MouseWheel"/>
                </Grid>
            </GroupBox>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="#222"/>

            <!-- B. LOGIC CORE: Shared space between Editor and Builder -->
            <Grid Grid.Column="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="400" MinWidth="300" />
                </Grid.ColumnDefinitions>

                <!-- 1. Scripting Engine -->
                <GroupBox Header="LOGIC ENGINE" Margin="4,8,4,8" BorderThickness="1" BorderBrush="#222">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="#1a1a1a" Padding="8,4">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="New" Command="{Binding ScriptEditor.NewScriptCommand}" Style="{StaticResource ToolbarButtonStyle}" FontSize="10"/>
                                <Button Content="Open" Command="{Binding ScriptEditor.OpenScriptCommand}" Style="{StaticResource ToolbarButtonStyle}" FontSize="10"/>
                                <Button Content="Save" Command="{Binding ScriptEditor.SaveScriptCommand}" Style="{StaticResource ToolbarButtonStyle}" FontSize="10"/>
                                <Button Content="Save As..." Command="{Binding ScriptEditor.SaveScriptAsCommand}" Style="{StaticResource ToolbarButtonStyle}" FontSize="10"/>
                                
                                <Separator Margin="10,0" Opacity="0.2"/>
                                <TextBox x:Name="SnippetNameInput" Width="100" Height="22" FontSize="10" Margin="4,0" ui:ControlHelper.PlaceholderText="Snippet Name..."/>
                                <Button Content="Save as Snippet" Click="SaveSnippet_Click" Style="{StaticResource ToolbarButtonStyle}" FontSize="10" Background="#2c3e50" Foreground="White"/>
                            </StackPanel>
                        </Border>
                        
                        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="0,5,0,0">
                            <TabItem Header="CODE">
                                <avalonedit:TextEditor Name="ScriptEditor"
                                                       FontFamily="Consolas" FontSize="12pt"
                                                       Background="#1e1e1e" Foreground="#d4d4d4"
                                                       ShowLineNumbers="True" SyntaxHighlighting="Python"
                                                       TextChanged="ScriptEditor_TextChanged" />
                            </TabItem>
                            <TabItem Header="VISUAL GRAPH">
                                <local:VisualEditorView DataContext="{Binding VisualEditor}"/>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </GroupBox>

                <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="#222"/>

                <!-- 2. Integrated Tool Dock (Builder + Regions + Tree) -->
                <Border Grid.Column="2" Background="#1a1a1a" BorderBrush="#222" BorderThickness="1,0,0,0" Margin="4,8,8,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="300" />
                        </Grid.RowDefinitions>

                        <!-- ACTION BUILDER (Refined Fonts) -->
                        <ScrollViewer Padding="12">
                            <StackPanel>
                                <TextBlock Text="ACTION BUILDER" Style="{StaticResource StudioHeader}"/>
                                <ListBox ItemsSource="{Binding Templates.FilteredTemplates}" 
                                         SelectedItem="{Binding Templates.SelectedTemplate}"
                                         Background="Transparent" BorderThickness="0" Margin="0,0,0,12">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Width="42" Height="42" Background="#252525" CornerRadius="4" Margin="2" ToolTip="{Binding Name}">
                                                <TextBlock Text="{Binding Icon}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <GroupBox Header="CONFIGURATION">
                                    <StackPanel Margin="10">
                                        <TextBlock Text="{Binding Templates.SelectedTemplate.Name}" FontWeight="Bold" FontSize="13" Foreground="{DynamicResource SystemControlHighlightAccentBrush}"/>
                                        <TextBlock Text="{Binding Templates.SelectedTemplate.Description}" FontSize="11" Foreground="#777" TextWrapping="Wrap" Margin="0,4,0,12"/>

                                        <ItemsControl ItemsSource="{Binding Templates.CurrentParams}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,10">
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Key}" VerticalAlignment="Center" FontSize="11" Foreground="#888" TextAlignment="Right" Margin="0,0,10,0"/>
                                                        <ContentControl Grid.Column="1" Content="{Binding}">
                                                            <ContentControl.Resources>
                                                                <DataTemplate x:Key="RegionPicker">
                                                                    <ComboBox ItemsSource="{Binding DataContext.Templates.AvailableRegions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                              SelectedItem="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Height="28" FontSize="12" IsEditable="True"/>
                                                                </DataTemplate>
                                                                <DataTemplate x:Key="ButtonPicker">
                                                                    <ComboBox SelectedItem="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Height="28" FontSize="12">
                                                                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">left</System:String>
                                                                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">right</System:String>
                                                                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">middle</System:String>
                                                                    </ComboBox>
                                                                </DataTemplate>
                                                                <DataTemplate x:Key="ModifierPicker">
                                                                    <ComboBox SelectedItem="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Height="28" FontSize="12">
                                                                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">[]</System:String>
                                                                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">['ctrl']</System:String>
                                                                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">['shift']</System:String>
                                                                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">['alt']</System:String>
                                                                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">['ctrl', 'shift']</System:String>
                                                                    </ComboBox>
                                                                </DataTemplate>
                                                                <DataTemplate x:Key="ColorPicker">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="30"/><ColumnDefinition Width="30"/></Grid.ColumnDefinitions>
                                                                        <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Height="28" FontSize="12"/>
                                                                        <Border Grid.Column="1" Background="{Binding Value}" CornerRadius="2" Margin="4,0,0,0" BorderBrush="#444" BorderThickness="1"/>
                                                                        <Button Grid.Column="2" Content="..." Padding="0" Margin="4,0,0,0" Height="28"
                                                                                Command="{Binding DataContext.Templates.PickColorCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                CommandParameter="{Binding}"/>
                                                                    </Grid>
                                                                </DataTemplate>
                                                                <DataTemplate x:Key="DefaultEditor">
                                                                    <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Height="28" FontSize="12"/>
                                                                </DataTemplate>
                                                            </ContentControl.Resources>
                                                            <ContentControl.Style>
                                                                <Style TargetType="ContentControl">
                                                                    <Setter Property="ContentTemplate" Value="{StaticResource DefaultEditor}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Type}" Value="region"><Setter Property="ContentTemplate" Value="{StaticResource RegionPicker}"/></DataTrigger>
                                                                        <DataTrigger Binding="{Binding Type}" Value="button"><Setter Property="ContentTemplate" Value="{StaticResource ButtonPicker}"/></DataTrigger>
                                                                        <DataTrigger Binding="{Binding Type}" Value="modifiers"><Setter Property="ContentTemplate" Value="{StaticResource ModifierPicker}"/></DataTrigger>
                                                                        <DataTrigger Binding="{Binding Type}" Value="color"><Setter Property="ContentTemplate" Value="{StaticResource ColorPicker}"/></DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ContentControl.Style>
                                                        </ContentControl>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <Button Content="INSERT CODE" Click="InsertTemplate_Click" HorizontalAlignment="Stretch" Margin="0,10,0,0" Style="{StaticResource AccentButtonStyle}" FontWeight="Bold" Height="35"/>
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>
                        </ScrollViewer>

                        <GridSplitter Grid.Row="1" Height="2" HorizontalAlignment="Stretch" Background="#222"/>

                        <!-- BOTTOM TABS (Regions / UIA) -->
                        <TabControl Grid.Row="2" Background="Transparent" BorderThickness="0,1,0,0" BorderBrush="#222">
                            <TabItem Header="📍 REGIONS">
                                <ListBox ItemsSource="{Binding Capture.Regions}" SelectedItem="{Binding Capture.SelectedRegion}" Background="#151515" BorderThickness="0">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Button Command="{Binding DataContext.Capture.PickRegionColorCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Padding="0" Margin="4,4,8,4" BorderThickness="1" BorderBrush="#444" Width="12" Height="12" Background="{Binding Color}"
                                                        ToolTip="Click to change region color"/>
                                                <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                                                         Background="Transparent" BorderThickness="0" Foreground="#ccc" FontSize="10" 
                                                         VerticalAlignment="Center" LostFocus="RegionName_LostFocus"/>
                                                <Button Grid.Column="2" Content="✕" FontSize="8" Padding="4,0" Background="Transparent" Foreground="#c0392b"
                                                        Command="{Binding DataContext.Capture.DeleteRegionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </TabItem>
                            <TabItem Header="🌳 UIA TREE">
                                <TreeView ItemsSource="{Binding AutomationTree.RootNodes}" Background="#151515" BorderThickness="0" SelectedItemChanged="AutomationTree_SelectedItemChanged">
                                    <TreeView.ItemTemplate>
                                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                            <TextBlock Text="{Binding Name}" FontSize="10" Foreground="#aaa">
                                                <TextBlock.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="Direct Click (Sidecar)" 
                                                                  Command="{Binding DataContext.AutomationTree.ClickNodeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                  CommandParameter="{Binding}"/>
                                                    </ContextMenu>
                                                </TextBlock.ContextMenu>
                                            </TextBlock>
                                        </HierarchicalDataTemplate>
                                    </TreeView.ItemTemplate>
                                </TreeView>
                            </TabItem>
                            <TabItem Header="⚙️ SIDECAR">
                                <Grid Margin="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Button Content="RESTART BRAIN" Command="{Binding Sidecar.RestartSidecarCommand}" 
                                                Background="#c0392b" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                        <Button Content="Clear Logs" Command="{Binding Sidecar.ClearLogsCommand}" Margin="10,0,0,0" FontSize="10"/>
                                    </StackPanel>
                                    <TextBox Grid.Row="1" Text="{Binding Sidecar.LogsText, Mode=OneWay}" 
                                             IsReadOnly="True" Background="#050505" Foreground="#f39c12" 
                                             FontSize="9" FontFamily="Consolas" BorderThickness="0"
                                             TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                             TextChanged="Terminal_TextChanged"/>
                                    <TextBlock Grid.Row="2" Text="{Binding Sidecar.StatusText}" 
                                               FontSize="9" Foreground="#858585" Margin="0,5,0,0"/>
                                </Grid>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- 3. TERMINAL -->
        <GridSplitter Grid.Row="2" Height="2" HorizontalAlignment="Stretch" Background="#222" />
        <Border Grid.Row="3" Background="#0a0a0a" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="SYSTEM TERMINAL" Style="{StaticResource StudioHeader}"/>
                <TextBox Grid.Row="1" Text="{Binding ScriptEditor.LogsText, Mode=OneWay}" 
                         IsReadOnly="True" Background="Transparent" BorderThickness="0" 
                         Foreground="#00FF00" FontFamily="Consolas" FontSize="11"
                         TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         TextChanged="Terminal_TextChanged"/>
            </Grid>
        </Border>
    </Grid>
</Window>
