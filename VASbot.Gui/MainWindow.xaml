<Window x:Class="VASbot.Gui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:services="clr-namespace:VASbot.Gui.UI.Converters"
        xmlns:vm="clr-namespace:VASbot.Gui.UI.ViewModels"
        xmlns:eng="clr-namespace:VASbot.Gui.Engine"
        xmlns:local="clr-namespace:VASbot.Gui.UI.Views"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="VASbot3 Studio" Height="1000" Width="1800"
        Icon="Resources/icon.png"
        Background="#121212">

    <Window.Resources>
        <Style x:Key="ToolbarButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <services:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <services:EnumValuesConverter x:Key="EnumValuesConverter" />
        <services:BooleanToRedConverter x:Key="BooleanToRedConverter" />
        <services:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        
        <Style x:Key="StudioHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </Window.Resources>

    <Window.InputBindings>
        <!-- Global Hotkeys for Script Control -->
        <KeyBinding Key="F5" Command="{Binding ScriptEditor.RunScriptCommand}"/>
        <KeyBinding Key="F6" Command="{Binding ScriptEditor.StopScriptCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Global Ribbon -->
            <RowDefinition Height="*" />    <!-- Main Workspace -->
            <RowDefinition Height="Auto" /> <!-- Terminal Splitter -->
            <RowDefinition Height="220" MinHeight="100" /> <!-- Console -->
        </Grid.RowDefinitions>

        <!-- 1. GLOBAL RIBBON (Control Plane) -->
        <Border Background="#1e1e1e" BorderBrush="#222" BorderThickness="0,0,0,1" Padding="16,10">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="VASbot3" FontWeight="Black" FontSize="20" Foreground="{DynamicResource SystemControlHighlightAccentBrush}" VerticalAlignment="Center" Margin="0,0,30,0"/>
                    
                    <ui:SimpleStackPanel Orientation="Horizontal" Spacing="12">
                        <ComboBox ItemsSource="{Binding Capture.WindowList}" 
                                  SelectedItem="{Binding Capture.SelectedWindow}"
                                  Width="350" ui:ControlHelper.PlaceholderText="Select Target Window..." AutomationProperties.Name="Target Window" ToolTip="Select Target Window">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,2">
                                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="12"/>
                                        <TextBlock Text="{Binding ClassName}" FontSize="9" Foreground="#858585"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Content="🔄" Command="{Binding Capture.RefreshWindowsCommand}" ToolTip="Refresh Window List" AutomationProperties.Name="Refresh Window List"/>
                        
                        <Separator Margin="10,0" Opacity="0.2"/>
                        
                        <Button Content="▶ RUN" Command="{Binding ScriptEditor.RunScriptCommand}" AutomationProperties.Name="Run Script" Background="#27ae60" Foreground="White" FontWeight="Bold" Width="90" ToolTip="F5 - Run script"/>
                        <Button Content="⏹ STOP" Command="{Binding ScriptEditor.StopScriptCommand}" AutomationProperties.Name="Stop Script" Background="#c0392b" Foreground="White" FontWeight="Bold" Width="90" ToolTip="F6 - Stop script"/>
                        <Button Content="☠️ KILL" Click="Killswitch_Click" AutomationProperties.Name="Force Kill Everything" Background="#8b0000" Foreground="White" FontWeight="Bold" Width="70" ToolTip="F12 - Force kill everything"/>
                        <ToggleButton Content="⏺ REC" Command="{Binding ScriptEditor.ToggleRecordingCommand}" 
                                      AutomationProperties.Name="Toggle Recording" ToolTip="Toggle Recording"
                                      IsChecked="{Binding ScriptEditor.IsRecording, Mode=OneWay}"
                                      Background="{Binding ScriptEditor.IsRecording, Converter={StaticResource BooleanToRedConverter}}"
                                      Foreground="White" FontWeight="Bold" Width="80"/>

                        <Separator Margin="10,0" Opacity="0.2"/>
                        
                        <ToggleButton Content="🎬 LIVE MIRROR" IsChecked="{Binding Capture.IsReflecting}" 
                                      AutomationProperties.Name="Toggle Live Mirror" ToolTip="Toggle Live Mirror"
                                      Background="{Binding Capture.IsReflecting, Converter={StaticResource BooleanToRedConverter}}"
                                      Foreground="White" FontWeight="Bold" Width="130"/>
                        
                        <ToggleButton Content="🖥️ OVERLAY" IsChecked="{Binding Capture.IsOverlayMirrorActive}" 
                                      AutomationProperties.Name="Toggle Overlay Mirror"
                                      ToolTip="Popout a transparent overlay directly on top of the target window client area"
                                      Background="{Binding Capture.IsOverlayMirrorActive, Converter={StaticResource BooleanToRedConverter}}"
                                      Foreground="White" FontWeight="Bold" Width="100"
                                      />

                        <ToggleButton Content="🖱️ CLICK-THRU" IsChecked="{Binding Capture.IsOverlayClickThrough}" 
                                      Visibility="{Binding Capture.IsOverlayMirrorActive, Converter={StaticResource BooleanToVisibilityConverter}}"
                                      AutomationProperties.Name="Toggle Overlay Click-Through"
                                      ToolTip="Enable click-through so clicks pass directly to the target window. Disable to select/create regions on the overlay."
                                      Background="{Binding Capture.IsOverlayClickThrough, Converter={StaticResource BooleanToRedConverter}}"
                                      Foreground="White" FontWeight="Bold" Width="115"
                                      />
                        
                        <Button Content="📸 SNAP" Command="{Binding Capture.StaticCaptureCommand}" 
                                AutomationProperties.Name="Take Static Screenshot"
                                Visibility="{Binding Capture.IsReflecting, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Inverse}"
                                ToolTip="Take a manual printscreen"
                                />

                        <Separator Margin="10,0" Opacity="0.2"/>

                        <!-- Color Ribbon Tool -->
                        <StackPanel Orientation="Horizontal">
                            <ToggleButton Content="💧" IsChecked="{Binding Capture.IsEyedropperActive}"
                                          AutomationProperties.Name="Toggle Eyedropper"
                                          ToolTip="Eyedropper: Pick color from image"
                                          Width="40"/>
                            <Border Width="30" Height="24" Background="{Binding Capture.PickedColor}" 
                                    BorderBrush="#444" BorderThickness="1" Margin="8,0,8,0" CornerRadius="2"
                                    ToolTip="Active Pen Color"/>
                            <TextBlock Text="{Binding Capture.PickedColor}" VerticalAlignment="Center" 
                                       Foreground="#858585" FontSize="10" FontFamily="Consolas" Width="60"/>
                        </StackPanel>
                    </ui:SimpleStackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Border CornerRadius="12" Background="#1a1a1a" Padding="15,5">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8" Fill="Lime" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Status}" Foreground="#888" FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 2. STUDIO WORKSPACE (v2 - Viewport Isolated) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />    <!-- Viewport -->
                <ColumnDefinition Width="Auto" /> <!-- Main Splitter -->
                <ColumnDefinition Width="1.5*" />  <!-- Logic Core (Resizable) -->
            </Grid.ColumnDefinitions>

            <!-- A. VIEWPORT: Isolated & Full Height -->
            <GroupBox Header="VIEWPORT" Margin="8,8,4,8" BorderThickness="1" BorderBrush="#222">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    
                    <!-- Canvas Area -->
                    <Grid Grid.Row="0" Background="#000" ClipToBounds="True">
                        <skia:SKElement x:Name="SkiaElement" 
                                        AutomationProperties.Name="Studio Viewport Canvas"
                                        PaintSurface="SkiaElement_PaintSurface"
                                        MouseDown="SkiaElement_MouseDown"
                                        MouseMove="SkiaElement_MouseMove"
                                        MouseUp="SkiaElement_MouseUp"
                                        MouseWheel="SkiaElement_MouseWheel"/>
                        
                        <!-- FLOATING VIEWPORT HUD -->
                        <Border VerticalAlignment="Top" HorizontalAlignment="Center" 
                                Margin="0,15,0,0" Padding="8,4" CornerRadius="8" 
                                Background="#E0111111" BorderBrush="#44FFFFFF" BorderThickness="1"
                                IsHitTestVisible="True">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Layer Toggles -->
                                <TextBlock Text="LAYERS:" Foreground="#888" FontSize="9" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0,10,0"/>
                                
                                <ToggleButton AutomationProperties.Name="Toggle Static Regions" IsChecked="{Binding Capture.IsRegionsVisible}" Padding="8,3" Height="22" FontSize="9" FontWeight="SemiBold" Background="#222222" Foreground="#D0D0D0" BorderBrush="#44FFFFFF" BorderThickness="1" Margin="2,0" ToolTip="Toggle Static Regions">Regions</ToggleButton>
                                <ToggleButton AutomationProperties.Name="Toggle Detected Shapes" IsChecked="{Binding Capture.IsShapesVisible}" Padding="8,3" Height="22" FontSize="9" FontWeight="SemiBold" Background="#222222" Foreground="#D0D0D0" BorderBrush="#44FFFFFF" BorderThickness="1" Margin="2,0" ToolTip="Toggle Detected Shapes">Shapes</ToggleButton>
                                
                                <!-- Conditional Shape Settings inside HUD -->
                                <StackPanel Orientation="Horizontal" Visibility="{Binding Capture.IsShapesVisible, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="4,0,0,0">
                                    <ComboBox SelectedValue="{Binding Capture.DetectShapeType, UpdateSourceTrigger=PropertyChanged}" Width="75" Height="22" FontSize="9" Padding="2,0" Background="#222222" Foreground="#D0D0D0" BorderBrush="#44FFFFFF" BorderThickness="1" Margin="2,0" AutomationProperties.Name="Detect Shape Type" ToolTip="Detect Shape Type">
                                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">all</System:String>
                                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">circle</System:String>
                                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">rectangle</System:String>
                                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">grid</System:String>
                                    </ComboBox>
                                    <TextBlock Text="Min:" Foreground="#888" FontSize="9" VerticalAlignment="Center" Margin="6,0,2,0"/>
                                    <TextBox Text="{Binding Capture.DetectMinSize, UpdateSourceTrigger=PropertyChanged}" Width="25" Height="22" FontSize="9" Background="#222222" Foreground="#D0D0D0" BorderBrush="#44FFFFFF" BorderThickness="1" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Margin="2,0" AutomationProperties.Name="Detect Min Size" ToolTip="Detect Min Size"/>
                                    <TextBlock Text="Max:" Foreground="#888" FontSize="9" VerticalAlignment="Center" Margin="6,0,2,0"/>
                                    <TextBox Text="{Binding Capture.DetectMaxSize, UpdateSourceTrigger=PropertyChanged}" Width="25" Height="22" FontSize="9" Background="#222222" Foreground="#D0D0D0" BorderBrush="#44FFFFFF" BorderThickness="1" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Margin="2,0" AutomationProperties.Name="Detect Max Size" ToolTip="Detect Max Size"/>
                                    <Button Content="🔮 DETECT" Command="{Binding Capture.DetectShapesCommand}" Height="22" Width="55" Style="{StaticResource AccentButtonStyle}" FontSize="9" FontWeight="Bold" Margin="4,0,2,0" AutomationProperties.Name="Detect Shapes" ToolTip="Detect Shapes"/>
                                </StackPanel>
                                
                                <ToggleButton AutomationProperties.Name="Toggle Color Clusters" IsChecked="{Binding Capture.IsClustersVisible}" Padding="8,3" Height="22" FontSize="9" FontWeight="SemiBold" Background="#222222" Foreground="#D0D0D0" BorderBrush="#44FFFFFF" BorderThickness="1" Margin="2,0" ToolTip="Toggle Color Clusters">Clusters</ToggleButton>
                                <ToggleButton AutomationProperties.Name="Toggle UIA Highlights" IsChecked="{Binding Capture.IsUiaVisible}" Padding="8,3" Height="22" FontSize="9" FontWeight="SemiBold" Background="#222222" Foreground="#D0D0D0" BorderBrush="#44FFFFFF" BorderThickness="1" Margin="2,0" ToolTip="Toggle UIA Highlights">UIA</ToggleButton>
                                
                                <Separator Width="1" Height="14" Background="#33FFFFFF" Margin="10,0"/>
                                
                                <TextBlock Text="ZOOM:" Foreground="#888" FontSize="9" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0,10,0"/>
                                
                                <!-- Zoom Controls -->
                                <Button Command="{Binding Capture.ZoomInCommand}" Padding="8,3" Height="22" FontSize="9" FontWeight="SemiBold" Background="#222222" Foreground="#D0D0D0" BorderBrush="#44FFFFFF" BorderThickness="1" Margin="2,0" ToolTip="Zoom In" AutomationProperties.Name="Zoom In">🔍➕</Button>
                                <Button Command="{Binding Capture.ZoomOutCommand}" Padding="8,3" Height="22" FontSize="9" FontWeight="SemiBold" Background="#222222" Foreground="#D0D0D0" BorderBrush="#44FFFFFF" BorderThickness="1" Margin="2,0" ToolTip="Zoom Out" AutomationProperties.Name="Zoom Out">🔍➖</Button>
                                <Button Command="{Binding Capture.ResetZoomCommand}" Padding="8,3" Height="22" FontSize="9" FontWeight="SemiBold" Background="#222222" Foreground="#D0D0D0" BorderBrush="#44FFFFFF" BorderThickness="1" Margin="2,0" ToolTip="Reset Zoom" AutomationProperties.Name="Reset Zoom">🎯 1:1</Button>
                            </StackPanel>
                        </Border>
                    </Grid>
                    
                    <!-- Telemetry Footer Bar -->
                    <Border Grid.Row="1" Background="#141414" BorderBrush="#222" BorderThickness="0,1,0,0" Padding="10,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Coordinates & Zoom info -->
                            <StackPanel Orientation="Horizontal" Grid.Column="0">
                                <TextBlock Text="COORD:" Foreground="#555" FontSize="9" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="{Binding Capture.TelemetryCoords}" Foreground="#A0A0A0" FontSize="11" FontFamily="Consolas" VerticalAlignment="Center" Width="220"/>
                                
                                <Separator Width="1" Height="12" Background="#222" Margin="10,0"/>
                                
                                <TextBlock Text="ZOOM:" Foreground="#555" FontSize="9" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="{Binding Capture.ZoomLevel, StringFormat={}{0:P0}}" Foreground="#A0A0A0" FontSize="11" FontFamily="Consolas" VerticalAlignment="Center" Width="60"/>
                            </StackPanel>
                            
                            <!-- Hovered Win32 Element Info -->
                            <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="ELEMENT:" Foreground="#555" FontSize="9" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="{Binding Capture.TelemetryElementInfo}" Foreground="#00FFCC" FontSize="11" FontFamily="Consolas" VerticalAlignment="Center"/>
                            </StackPanel>
                            
                            <!-- Color Sample Swatch & Hex -->
                            <StackPanel Orientation="Horizontal" Grid.Column="2">
                                <TextBlock Text="COLOR:" Foreground="#555" FontSize="9" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <Border Width="16" Height="12" CornerRadius="2" Background="{Binding Capture.TelemetryColorHex}" BorderBrush="#44FFFFFF" BorderThickness="1" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <TextBlock Text="{Binding Capture.TelemetryColorHex}" Foreground="#A0A0A0" FontSize="11" FontFamily="Consolas" VerticalAlignment="Center" Width="70"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </GroupBox>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="#222" AutomationProperties.Name="Viewport and Logic Core Splitter" ToolTip="Resize Viewport and Logic Core"/>

            <!-- B. LOGIC CORE: Shared space between Editor and Builder -->
            <Grid Grid.Column="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="400" MinWidth="300" />
                </Grid.ColumnDefinitions>

                <!-- 1. Scripting Engine -->
                <GroupBox Header="LOGIC ENGINE" Margin="4,8,4,8" BorderThickness="1" BorderBrush="#222">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="#1a1a1a" Padding="8,4">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="New" Command="{Binding ScriptEditor.NewScriptCommand}" Style="{StaticResource ToolbarButtonStyle}" FontSize="10" AutomationProperties.Name="New Script" ToolTip="New Script"/>
                                <Button Content="Open" Command="{Binding ScriptEditor.OpenScriptCommand}" Style="{StaticResource ToolbarButtonStyle}" FontSize="10" AutomationProperties.Name="Open Script" ToolTip="Open Script"/>
                                <Button Content="Save" Command="{Binding ScriptEditor.SaveScriptCommand}" Style="{StaticResource ToolbarButtonStyle}" FontSize="10" AutomationProperties.Name="Save Script" ToolTip="Save Script"/>
                                <Button Content="Save As..." Command="{Binding ScriptEditor.SaveScriptAsCommand}" Style="{StaticResource ToolbarButtonStyle}" FontSize="10" AutomationProperties.Name="Save Script As" ToolTip="Save Script As"/>
                                
                                <Separator Margin="10,0" Opacity="0.2"/>
                                <TextBox x:Name="SnippetNameInput" Width="100" Height="22" FontSize="10" Margin="4,0" ui:ControlHelper.PlaceholderText="Snippet Name..." AutomationProperties.Name="Snippet Name" ToolTip="Snippet Name"/>
                                <Button Content="Save as Snippet" Click="SaveSnippet_Click" Style="{StaticResource ToolbarButtonStyle}" FontSize="10" Background="#2c3e50" Foreground="White" AutomationProperties.Name="Save as Snippet" ToolTip="Save as Snippet"/>
                                <Button Content="Insert Image..." Click="InsertImage_Click" Style="{StaticResource ToolbarButtonStyle}" FontSize="10" Background="#16a085" Foreground="White" Margin="4,0" AutomationProperties.Name="Insert Image" ToolTip="Insert Image"/>
                                <Button Content="📖 API Drawer" Click="ToggleDrawer_Click" Style="{StaticResource ToolbarButtonStyle}" FontSize="10" Background="#8e44ad" Foreground="White" Margin="4,0" AutomationProperties.Name="Toggle API Drawer" ToolTip="Toggle API Drawer"/>
                            </StackPanel>
                        </Border>
                        
                        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="0,5,0,0">
                            <TabItem Header="CODE" AutomationProperties.Name="Code Editor" ToolTip="Code Editor Workspace">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <avalonedit:TextEditor Name="ScriptEditor" Grid.Column="0"
                                                           FontFamily="Consolas" FontSize="12pt"
                                                           Background="#121212" Foreground="#E0E0E0"
                                                           ShowLineNumbers="True" SyntaxHighlighting="Python"
                                                           TextChanged="ScriptEditor_TextChanged"
                                                           PreviewMouseMove="ScriptEditor_PreviewMouseMove"
                                                           AutomationProperties.Name="Script Editor" ToolTip="Script Editor" />
                                                            
                                    <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="#222" 
                                                  Visibility="{Binding ElementName=SnippetDrawer, Path=Visibility}"
                                                  AutomationProperties.Name="Script Editor and API Drawer Splitter" ToolTip="Resize Script Editor and API Drawer"/>
                                                   
                                    <Border x:Name="SnippetDrawer" Grid.Column="2" Width="260" Visibility="Collapsed" Background="#1c1c1c" BorderBrush="#333" BorderThickness="1,0,0,0">
                                        <Grid Margin="10">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                             
                                            <TextBlock Text="API HELPER DRAWER" FontWeight="Bold" FontSize="11" Foreground="#888" Margin="0,0,0,10"/>
                                             
                                            <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0" Margin="0">
                                                <TabItem Header="CORE" FontSize="10" Padding="6,4" AutomationProperties.Name="Core API Snippets" ToolTip="Core Automation API Snippets">
                                                    <ListBox x:Name="CoreSnippetList" Background="Transparent" BorderThickness="0" MouseDoubleClick="SnippetList_MouseDoubleClick" ScrollViewer.HorizontalScrollBarVisibility="Disabled" AutomationProperties.Name="Core Snippets List" ToolTip="List of core automation snippets">
                                                        <ListBox.ItemContainerStyle>
                                                            <Style TargetType="ListBoxItem">
                                                                <Setter Property="Padding" Value="6,4"/>
                                                                <Setter Property="Margin" Value="0,2"/>
                                                            </Style>
                                                        </ListBox.ItemContainerStyle>
                                                        <ListBoxItem Tag="bot.click(x, y, button='left')">
                                                            <StackPanel>
                                                                <TextBlock Text="bot.click" FontWeight="Bold" Foreground="#00FFCC" FontSize="11"/>
                                                                <TextBlock Text="Click coordinates (x, y)" FontSize="9" Foreground="#888" TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </ListBoxItem>
                                                        <ListBoxItem Tag="bot.double_click(x, y, button='left')">
                                                            <StackPanel>
                                                                <TextBlock Text="bot.double_click" FontWeight="Bold" Foreground="#00FFCC" FontSize="11"/>
                                                                <TextBlock Text="Double click coordinates" FontSize="9" Foreground="#888" TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </ListBoxItem>
                                                        <ListBoxItem Tag="bot.move_mouse(x, y)">
                                                            <StackPanel>
                                                                <TextBlock Text="bot.move_mouse" FontWeight="Bold" Foreground="#00FFCC" FontSize="11"/>
                                                                <TextBlock Text="Move mouse to position" FontSize="9" Foreground="#888" TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </ListBoxItem>
                                                        <ListBoxItem Tag="bot.wait(1.0)">
                                                            <StackPanel>
                                                                <TextBlock Text="bot.wait" FontWeight="Bold" Foreground="#00FFCC" FontSize="11"/>
                                                                <TextBlock Text="Pause script (seconds)" FontSize="9" Foreground="#888" TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </ListBoxItem>
                                                        <ListBoxItem Tag="bot.type_text('hello', delay=0.05)">
                                                            <StackPanel>
                                                                <TextBlock Text="bot.type_text" FontWeight="Bold" Foreground="#00FFCC" FontSize="11"/>
                                                                <TextBlock Text="Type raw keyboard text" FontSize="9" Foreground="#888" TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </ListBoxItem>
                                                        <ListBoxItem Tag="bot.scroll(clicks=5)">
                                                            <StackPanel>
                                                                <TextBlock Text="bot.scroll" FontWeight="Bold" Foreground="#00FFCC" FontSize="11"/>
                                                                <TextBlock Text="Scroll mouse wheel" FontSize="9" Foreground="#888" TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </ListBoxItem>
                                                    </ListBox>
                                                </TabItem>
                                                 
                                                <TabItem Header="VISION" FontSize="10" Padding="6,4" AutomationProperties.Name="Vision API Snippets" ToolTip="Computer Vision API Snippets">
                                                    <ListBox x:Name="VisionSnippetList" Background="Transparent" BorderThickness="0" MouseDoubleClick="SnippetList_MouseDoubleClick" ScrollViewer.HorizontalScrollBarVisibility="Disabled" AutomationProperties.Name="Vision Snippets List" ToolTip="List of vision automation snippets">
                                                        <ListBox.ItemContainerStyle>
                                                            <Style TargetType="ListBoxItem">
                                                                <Setter Property="Padding" Value="6,4"/>
                                                                <Setter Property="Margin" Value="0,2"/>
                                                            </Style>
                                                        </ListBox.ItemContainerStyle>
                                                        <ListBoxItem Tag="bot.click_region(region_index=0)">
                                                            <StackPanel>
                                                                <TextBlock Text="bot.click_region" FontWeight="Bold" Foreground="#BB86FC" FontSize="11"/>
                                                                <TextBlock Text="Click inside selected region" FontSize="9" Foreground="#888" TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </ListBoxItem>
                                                        <ListBoxItem Tag="bot.find_color('#FF0000', region_index=0, tolerance=10)">
                                                            <StackPanel>
                                                                <TextBlock Text="bot.find_color" FontWeight="Bold" Foreground="#BB86FC" FontSize="11"/>
                                                                <TextBlock Text="Find color coords in region" FontSize="9" Foreground="#888" TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </ListBoxItem>
                                                        <ListBoxItem Tag="bot.find_and_click_color('#FF0000', region_index=0)">
                                                            <StackPanel>
                                                                <TextBlock Text="bot.find_and_click_color" FontWeight="Bold" Foreground="#BB86FC" FontSize="11"/>
                                                                <TextBlock Text="Find color and click it" FontSize="9" Foreground="#888" TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </ListBoxItem>
                                                        <ListBoxItem Tag="pos = bot.find_image('img/template.png', confidence=0.8)&#x0a;if pos:&#x0a;    bot.click(pos[0], pos[1])">
                                                            <StackPanel>
                                                                <TextBlock Text="bot.find_image" FontWeight="Bold" Foreground="#BB86FC" FontSize="11"/>
                                                                <TextBlock Text="Find template PNG image" FontSize="9" Foreground="#888" TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </ListBoxItem>
                                                        <ListBoxItem Tag="text = bot.ocr_region(region_index=0)">
                                                            <StackPanel>
                                                                <TextBlock Text="bot.ocr_region" FontWeight="Bold" Foreground="#BB86FC" FontSize="11"/>
                                                                <TextBlock Text="Get text via OCR in region" FontSize="9" Foreground="#888" TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </ListBoxItem>
                                                    </ListBox>
                                                </TabItem>
                                                 
                                                <TabItem Header="UI AUTO" FontSize="10" Padding="6,4" AutomationProperties.Name="UI Automation API Snippets" ToolTip="UI Automation API Snippets">
                                                    <ListBox x:Name="UiSnippetList" Background="Transparent" BorderThickness="0" MouseDoubleClick="SnippetList_MouseDoubleClick" ScrollViewer.HorizontalScrollBarVisibility="Disabled" AutomationProperties.Name="UI Snippets List" ToolTip="List of UI automation snippets">
                                                        <ListBox.ItemContainerStyle>
                                                            <Style TargetType="ListBoxItem">
                                                                <Setter Property="Padding" Value="6,4"/>
                                                                <Setter Property="Margin" Value="0,2"/>
                                                            </Style>
                                                        </ListBox.ItemContainerStyle>
                                                        <ListBoxItem Tag="bot.click_element('ButtonName', control_type='Button')">
                                                            <StackPanel>
                                                                <TextBlock Text="bot.click_element" FontWeight="Bold" Foreground="#3498db" FontSize="11"/>
                                                                <TextBlock Text="Click Win32 UIA element" FontSize="9" Foreground="#888" TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </ListBoxItem>
                                                        <ListBoxItem Tag="bot.type_into('EditName', 'text')">
                                                            <StackPanel>
                                                                <TextBlock Text="bot.type_into" FontWeight="Bold" Foreground="#3498db" FontSize="11"/>
                                                                <TextBlock Text="Type into UIA text box" FontSize="9" Foreground="#888" TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </ListBoxItem>
                                                        <ListBoxItem Tag="text = bot.get_text('TextName')">
                                                            <StackPanel>
                                                                <TextBlock Text="bot.get_text" FontWeight="Bold" Foreground="#3498db" FontSize="11"/>
                                                                <TextBlock Text="Get text of UIA element" FontSize="9" Foreground="#888" TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </ListBoxItem>
                                                        <ListBoxItem Tag="bot.select_dropdown('ComboName', 'Option')">
                                                            <StackPanel>
                                                                <TextBlock Text="bot.select_dropdown" FontWeight="Bold" Foreground="#3498db" FontSize="11"/>
                                                                <TextBlock Text="Select item in combobox" FontSize="9" Foreground="#888" TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </ListBoxItem>
                                                        <ListBoxItem Tag="bot.check_checkbox('CheckboxName', state=True)">
                                                            <StackPanel>
                                                                <TextBlock Text="bot.check_checkbox" FontWeight="Bold" Foreground="#3498db" FontSize="11"/>
                                                                <TextBlock Text="Set checkbox state" FontSize="9" Foreground="#888" TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </ListBoxItem>
                                                        <ListBoxItem Tag="bot.wait_for_element('ButtonName')">
                                                            <StackPanel>
                                                                <TextBlock Text="bot.wait_for_element" FontWeight="Bold" Foreground="#3498db" FontSize="11"/>
                                                                <TextBlock Text="Wait for element to appear" FontSize="9" Foreground="#888" TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </ListBoxItem>
                                                    </ListBox>
                                                </TabItem>
                                            </TabControl>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </TabItem>
                            <TabItem Header="VISUAL GRAPH" AutomationProperties.Name="Visual Graph Editor" ToolTip="Visual Node Graph Editor">
                                <local:VisualEditorView DataContext="{Binding VisualEditor}"/>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </GroupBox>

                <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Background="#222" AutomationProperties.Name="Logic Engine and Tool Dock Splitter" ToolTip="Resize Logic Engine and Tool Dock"/>

                <!-- 2. Integrated Tool Dock (Builder + Regions + Tree) -->
                <Border Grid.Column="2" Background="#1a1a1a" BorderBrush="#222" BorderThickness="1,0,0,0" Margin="4,8,8,8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="300" />
                        </Grid.RowDefinitions>

                        <!-- ACTION BUILDER (Refined Fonts) -->
                        <ScrollViewer Padding="12" AutomationProperties.Name="Template configuration scroll view" ToolTip="Scroll view for template settings">
                            <StackPanel>
                                <TextBlock Text="ACTION BUILDER" Style="{StaticResource StudioHeader}"/>
                                <TextBox Text="{Binding Templates.SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                                         ui:ControlHelper.PlaceholderText="Search actions..."
                                         Margin="0,0,0,12" Height="32" Padding="8,4" FontSize="12"
                                         Background="#222" Foreground="#fff" BorderBrush="#3a3a3a"
                                         VerticalContentAlignment="Center" AutomationProperties.Name="Search actions" ToolTip="Search actions"/>

                                <ItemsControl ItemsSource="{Binding Templates.GroupedTemplates}" Margin="0,0,0,12">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Expander Header="{Binding HeaderText}" 
                                                      IsExpanded="{Binding IsExpanded, Mode=TwoWay}"
                                                      Margin="0,0,0,6"
                                                      Background="#202020" BorderBrush="#2a2a2a" BorderThickness="1"
                                                      Padding="0"
                                                      AutomationProperties.Name="{Binding HeaderText}" ToolTip="{Binding HeaderText}"
                                                      >
                                                <ListBox ItemsSource="{Binding Templates}"
                                                         SelectedItem="{Binding DataContext.Templates.SelectedTemplate, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
                                                         Background="Transparent" BorderThickness="0" Margin="0" Padding="0"
                                                         HorizontalContentAlignment="Stretch" AutomationProperties.Name="Action Templates List" ToolTip="List of available action templates">
                                                    <ListBox.ItemContainerStyle>
                                                        <Style TargetType="ListBoxItem">
                                                            <Setter Property="Padding" Value="8,6"/>
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Setter Property="BorderThickness" Value="0"/>
                                                            <Setter Property="Margin" Value="0,1"/>
                                                            <Style.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter Property="Background" Value="#2A2A2A"/>
                                                                </Trigger>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter Property="Background" Value="#1A3333"/>
                                                                </Trigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </ListBox.ItemContainerStyle>
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,2">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Border Grid.Column="0" Width="26" Height="26" Background="#2c2c2c" CornerRadius="4" Margin="0,0,8,0">
                                                                    <TextBlock Text="{Binding Icon}" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                </Border>
                                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="11" Foreground="#eee"/>
                                                                    <TextBlock Text="{Binding Description}" FontSize="9" Foreground="#888" TextWrapping="Wrap" Margin="0,1,0,0"/>
                                                                </StackPanel>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </Expander>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <GroupBox Header="CONFIGURATION">
                                    <StackPanel Margin="10">
                                        <TextBlock Text="{Binding Templates.SelectedTemplate.Name}" FontWeight="Bold" FontSize="13" Foreground="{DynamicResource SystemControlHighlightAccentBrush}"/>
                                        <TextBlock Text="{Binding Templates.SelectedTemplate.Description}" FontSize="11" Foreground="#777" TextWrapping="Wrap" Margin="0,4,0,12"/>

                                        <ItemsControl ItemsSource="{Binding Templates.CurrentParams}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,10">
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="90"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Key}" VerticalAlignment="Center" FontSize="11" Foreground="#888" TextAlignment="Right" Margin="0,0,10,0"/>
                                                        <ContentControl Grid.Column="1" Content="{Binding}">
                                                            <ContentControl.Resources>
                                                                <DataTemplate x:Key="RegionPicker">
                                                                    <ComboBox ItemsSource="{Binding DataContext.Templates.AvailableRegions, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                              SelectedItem="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Height="28" FontSize="12" IsEditable="True" AutomationProperties.Name="Select Region" ToolTip="Select Region"/>
                                                                </DataTemplate>
                                                                <DataTemplate x:Key="ButtonPicker">
                                                                    <ComboBox SelectedItem="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Height="28" FontSize="12" AutomationProperties.Name="Template Parameter Value" ToolTip="Template Parameter Value">
                                                                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">left</System:String>
                                                                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">right</System:String>
                                                                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">middle</System:String>
                                                                    </ComboBox>
                                                                </DataTemplate>
                                                                <DataTemplate x:Key="ModifierPicker">
                                                                    <ComboBox SelectedItem="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Height="28" FontSize="12" AutomationProperties.Name="Template Parameter Value" ToolTip="Template Parameter Value">
                                                                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">[]</System:String>
                                                                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">['ctrl']</System:String>
                                                                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">['shift']</System:String>
                                                                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">['alt']</System:String>
                                                                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">['ctrl', 'shift']</System:String>
                                                                    </ComboBox>
                                                                </DataTemplate>
                                                                <DataTemplate x:Key="ColorPicker">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="30"/><ColumnDefinition Width="30"/></Grid.ColumnDefinitions>
                                                                        <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Height="28" FontSize="12" AutomationProperties.Name="Template Parameter Value" ToolTip="Template Parameter Value"/>
                                                                        <Border Grid.Column="1" Background="{Binding Value}" CornerRadius="2" Margin="4,0,0,0" BorderBrush="#444" BorderThickness="1"/>
                                                                        <Button Grid.Column="2" Content="..." Padding="0" Margin="4,0,0,0" Height="28"
                                                                                AutomationProperties.Name="Pick Color" ToolTip="Pick Color"
                                                                                Command="{Binding DataContext.Templates.PickColorCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                CommandParameter="{Binding}"/>
                                                                    </Grid>
                                                                </DataTemplate>
                                                                <DataTemplate x:Key="BoolPicker">
                                                                    <ComboBox SelectedItem="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Height="28" FontSize="12" AutomationProperties.Name="Template Parameter Value" ToolTip="Template Parameter Value">
                                                                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">True</System:String>
                                                                        <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">False</System:String>
                                                                    </ComboBox>
                                                                </DataTemplate>
                                                                <DataTemplate x:Key="DefaultEditor">
                                                                    <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Height="28" FontSize="12" AutomationProperties.Name="Template Parameter Value" ToolTip="Template Parameter Value"/>
                                                                </DataTemplate>
                                                            </ContentControl.Resources>
                                                            <ContentControl.Style>
                                                                <Style TargetType="ContentControl">
                                                                    <Setter Property="ContentTemplate" Value="{StaticResource DefaultEditor}"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Type}" Value="region"><Setter Property="ContentTemplate" Value="{StaticResource RegionPicker}"/></DataTrigger>
                                                                        <DataTrigger Binding="{Binding Type}" Value="button"><Setter Property="ContentTemplate" Value="{StaticResource ButtonPicker}"/></DataTrigger>
                                                                        <DataTrigger Binding="{Binding Type}" Value="modifiers"><Setter Property="ContentTemplate" Value="{StaticResource ModifierPicker}"/></DataTrigger>
                                                                        <DataTrigger Binding="{Binding Type}" Value="color"><Setter Property="ContentTemplate" Value="{StaticResource ColorPicker}"/></DataTrigger>
                                                                        <DataTrigger Binding="{Binding Type}" Value="bool"><Setter Property="ContentTemplate" Value="{StaticResource BoolPicker}"/></DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ContentControl.Style>
                                                        </ContentControl>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Real-time Code Preview -->
                                        <TextBlock Text="CODE PREVIEW" FontSize="9" FontWeight="Bold" Foreground="#666" Margin="0,10,0,4"/>
                                        <Border Background="#0C0C0C" BorderBrush="#222" BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="0,0,0,10">
                                            <TextBox Text="{Binding Templates.CodePreview, Mode=OneWay}" 
                                                     Background="Transparent" BorderThickness="0" Foreground="#00FFCC" 
                                                     FontFamily="Consolas" FontSize="11" TextWrapping="NoWrap" 
                                                     IsReadOnly="True" IsReadOnlyCaretVisible="True" 
                                                     AcceptsReturn="True" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" MaxHeight="120"
                                                     AutomationProperties.Name="Code Preview" ToolTip="Code Preview"/>
                                        </Border>

                                        <Button Content="INSERT CODE" Click="InsertTemplate_Click" HorizontalAlignment="Stretch" Margin="0,10,0,0" Style="{StaticResource AccentButtonStyle}" FontWeight="Bold" Height="35" AutomationProperties.Name="Insert Code" ToolTip="Insert Code"/>
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>
                        </ScrollViewer>

                        <GridSplitter Grid.Row="1" Height="2" HorizontalAlignment="Stretch" Background="#222" AutomationProperties.Name="Action Builder and Bottom Tabs Splitter" ToolTip="Resize Action Builder and Bottom Tabs"/>

                        <!-- BOTTOM TABS (Regions / UIA) -->
                        <TabControl Grid.Row="2" Background="Transparent" BorderThickness="0,1,0,0" BorderBrush="#222">
                            <TabItem Header="📍 REGIONS" AutomationProperties.Name="Regions Configuration" ToolTip="Manage Region Configurations">
                                <Grid Background="#151515">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Shape Detection Toolbar -->
                                    <Border Grid.Row="0" Background="#1c1c1c" BorderBrush="#2d2d2d" BorderThickness="0,0,0,1" Padding="6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <!-- Shape Type -->
                                                <TextBlock Text="Type:" Foreground="#aaa" FontSize="9" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                <ComboBox SelectedValue="{Binding Capture.DetectShapeType, UpdateSourceTrigger=PropertyChanged}" Width="70" Height="22" FontSize="9" Padding="2,0" AutomationProperties.Name="Detect Shape Type" ToolTip="Detect Shape Type">
                                                    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">all</System:String>
                                                    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">circle</System:String>
                                                    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">rectangle</System:String>
                                                    <System:String xmlns:System="clr-namespace:System;assembly=mscorlib">grid</System:String>
                                                </ComboBox>

                                                <!-- Min Size -->
                                                <TextBlock Text="Min:" Foreground="#aaa" FontSize="9" VerticalAlignment="Center" Margin="8,0,4,0"/>
                                                <TextBox Text="{Binding Capture.DetectMinSize, UpdateSourceTrigger=PropertyChanged}" Width="35" Height="22" FontSize="9" Background="#222" Foreground="#fff" BorderBrush="#444" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" AutomationProperties.Name="Detect Min Size" ToolTip="Detect Min Size"/>

                                                <!-- Max Size -->
                                                <TextBlock Text="Max:" Foreground="#aaa" FontSize="9" VerticalAlignment="Center" Margin="8,0,4,0"/>
                                                <TextBox Text="{Binding Capture.DetectMaxSize, UpdateSourceTrigger=PropertyChanged}" Width="35" Height="22" FontSize="9" Background="#222" Foreground="#fff" BorderBrush="#444" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" AutomationProperties.Name="Detect Max Size" ToolTip="Detect Max Size"/>
                                            </StackPanel>

                                            <!-- Action Buttons -->
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button Content="🔮 DETECT" Command="{Binding Capture.DetectShapesCommand}" Height="22" Width="60" Style="{StaticResource AccentButtonStyle}" FontSize="9" FontWeight="Bold" AutomationProperties.Name="Detect Shapes" ToolTip="Detect Shapes"/>
                                                <Button Content="✕ CLEAR" Command="{Binding Capture.ClearDetectedShapesCommand}" Height="22" Width="55" Margin="4,0,0,0" Background="#2d2d2d" BorderBrush="#444" Foreground="#ccc" FontSize="9" FontWeight="Bold" AutomationProperties.Name="Clear Detected Shapes" ToolTip="Clear Detected Shapes"/>
                                                <Button Content="💾 SAVE SHAPE" Command="{Binding Capture.SaveSelectedShapeAsRegionCommand}" Visibility="{Binding Capture.IsSaveShapeVisible, Converter={StaticResource BooleanToVisibilityConverter}}" Height="22" Width="85" Margin="4,0,0,0" Style="{StaticResource AccentButtonStyle}" FontSize="9" FontWeight="Bold" AutomationProperties.Name="Save Shape" ToolTip="Save Shape"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Regions List -->
                                    <ListBox Grid.Row="1" ItemsSource="{Binding Capture.Regions}" SelectedItem="{Binding Capture.SelectedRegion}" Background="Transparent" BorderThickness="0" AutomationProperties.Name="Capture Regions List" ToolTip="List of defined capture regions">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Button Command="{Binding DataContext.Capture.PickRegionColorCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Padding="0" Margin="4,4,8,4" BorderThickness="1" BorderBrush="#444" Width="12" Height="12" Background="{Binding Color}"
                                                            ToolTip="Click to change region color" AutomationProperties.Name="Change region color"/>
                                                    <TextBox Grid.Column="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                                                             Background="Transparent" BorderThickness="0" Foreground="#ccc" FontSize="10" 
                                                             VerticalAlignment="Center" LostFocus="RegionName_LostFocus"
                                                             AutomationProperties.Name="Region Name" ToolTip="Region Name"/>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                        <Button Command="{Binding DataContext.Capture.SaveRegionAsPngCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"
                                                                Content="📸" FontSize="10" Padding="4,0" Margin="0,0,4,0" Background="Transparent" Foreground="White"
                                                                AutomationProperties.Name="Save Region as PNG" ToolTip="Save Region as PNG Template"/>
                                                        <Button Content="✕" FontSize="8" Padding="4,0" Background="Transparent" Foreground="#c0392b"
                                                                AutomationProperties.Name="Delete Region" ToolTip="Delete Region"
                                                                Command="{Binding DataContext.Capture.DeleteRegionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"/>
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <!-- Selected Region Inspector (Active/Depleted States) -->
                                    <Border Grid.Row="2" Background="#1c1c1c" BorderBrush="#2d2d2d" BorderThickness="0,1,0,0" Padding="8"
                                            Visibility="{Binding Capture.SelectedRegion, Converter={StaticResource NullToVisibilityConverter}}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Header -->
                                            <TextBlock Grid.ColumnSpan="2" Text="{Binding Capture.SelectedRegion.Name, StringFormat='REGION STATES: {0}'}" 
                                                       Foreground="#aaa" FontSize="9" FontWeight="Bold" Margin="0,0,0,6"/>

                                            <!-- Active Color State -->
                                            <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,0,4,0">
                                                <TextBlock Text="Active:" Foreground="#aaa" FontSize="9" VerticalAlignment="Center" Margin="0,0,4,0" ToolTip="Color indicating active/available state"/>
                                                <TextBox Text="{Binding Capture.SelectedRegion.ActiveColor, UpdateSourceTrigger=PropertyChanged}" Width="65" Height="20" FontSize="9" Background="#222" Foreground="#fff" BorderBrush="#444" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" LostFocus="RegionName_LostFocus" AutomationProperties.Name="Active Color" ToolTip="Active Color"/>
                                                <Button Content="🎨" Command="{Binding DataContext.Capture.PickRegionActiveColorCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding Capture.SelectedRegion}" 
                                                        AutomationProperties.Name="Pick active color from screen" ToolTip="Pick active color from screen"
                                                        Height="20" Width="20" Margin="2,0,0,0" FontSize="9" Background="#2d2d2d" BorderBrush="#444" Foreground="#ccc"/>
                                            </StackPanel>

                                            <!-- Depleted Color State -->
                                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="4,0,0,0">
                                                <TextBlock Text="Depleted:" Foreground="#aaa" FontSize="9" VerticalAlignment="Center" Margin="0,0,4,0" ToolTip="Color indicating depleted/empty state"/>
                                                <TextBox Text="{Binding Capture.SelectedRegion.DepletedColor, UpdateSourceTrigger=PropertyChanged}" Width="65" Height="20" FontSize="9" Background="#222" Foreground="#fff" BorderBrush="#444" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" LostFocus="RegionName_LostFocus" AutomationProperties.Name="Depleted Color" ToolTip="Depleted Color"/>
                                                <Button Content="🎨" Command="{Binding DataContext.Capture.PickRegionDepletedColorCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding Capture.SelectedRegion}" 
                                                        AutomationProperties.Name="Pick depleted color from screen" ToolTip="Pick depleted color from screen"
                                                        Height="20" Width="20" Margin="2,0,0,0" FontSize="9" Background="#2d2d2d" BorderBrush="#444" Foreground="#ccc"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </TabItem>
                            <TabItem Header="🎨 CLUSTERS" AutomationProperties.Name="Color Clusters Configuration" ToolTip="Manage Color Cluster Configurations">
                                <Grid Background="#151515">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="3*"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Left Column: Cluster List -->
                                    <Border BorderThickness="0,0,1,0" BorderBrush="#222">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            
                                            <ListBox ItemsSource="{Binding Capture.ColorClusters}" SelectedItem="{Binding Capture.SelectedColorCluster}" Background="Transparent" BorderThickness="0" AutomationProperties.Name="Color Clusters List" ToolTip="List of defined color clusters">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,2">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding Name}" Foreground="#ccc" FontSize="10" VerticalAlignment="Center"/>
                                                            <Button Grid.Column="1" Content="✕" FontSize="8" Padding="4,0" Background="Transparent" Foreground="#c0392b"
                                                                    AutomationProperties.Name="Delete Color Cluster" ToolTip="Delete Color Cluster"
                                                                    Command="{Binding DataContext.Capture.DeleteColorClusterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                            
                                            <Button Grid.Row="1" Content="+ ADD CLUSTER" Command="{Binding Capture.AddColorClusterCommand}" Height="24" Margin="4" Style="{StaticResource AccentButtonStyle}" FontSize="9" FontWeight="Bold" AutomationProperties.Name="Add Color Cluster" ToolTip="Add Color Cluster"/>
                                        </Grid>
                                    </Border>
                                    
                                    <!-- Right Column: Detail Panel -->
                                    <ScrollViewer Grid.Column="1" Padding="6" AutomationProperties.Name="Cluster configuration scroll view" ToolTip="Scroll view for cluster settings">
                                        <StackPanel>
                                            <TextBlock Text="CLUSTER CONFIGURATION" Foreground="#888" FontSize="9" FontWeight="Bold" Margin="0,0,0,6"/>
                                            
                                            <!-- Name -->
                                            <TextBlock Text="Name" Foreground="#aaa" FontSize="9" Margin="0,0,0,2"/>
                                            <TextBox Text="{Binding Capture.SelectedColorCluster.Name, UpdateSourceTrigger=PropertyChanged}" Background="#222" Foreground="#fff" BorderBrush="#444" FontSize="10" Padding="3" Margin="0,0,0,8" AutomationProperties.Name="Cluster Name" ToolTip="Cluster Name"/>
                                            
                                            <!-- Proximity Bridge -->
                                            <Grid Margin="0,0,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Proximity Bridge (Dilation)" Foreground="#aaa" FontSize="9"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Capture.SelectedColorCluster.Proximity, StringFormat={}{0}px}" Foreground="#00FFFF" FontSize="9" FontWeight="Bold"/>
                                            </Grid>
                                            <Slider Minimum="1" Maximum="40" Value="{Binding Capture.SelectedColorCluster.Proximity, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" AutomationProperties.Name="Proximity Bridge" ToolTip="Proximity Bridge Dilation in pixels"/>
                                            
                                            <!-- Tolerance -->
                                            <Grid Margin="0,0,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="RGB Tolerance" Foreground="#aaa" FontSize="9"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Capture.SelectedColorCluster.Tolerance}" Foreground="#00FFFF" FontSize="9" FontWeight="Bold"/>
                                            </Grid>
                                            <Slider Minimum="1" Maximum="100" Value="{Binding Capture.SelectedColorCluster.Tolerance, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8" AutomationProperties.Name="RGB Tolerance" ToolTip="RGB Tolerance"/>
                                            
                                            <!-- Active Checkbox -->
                                            <CheckBox AutomationProperties.Name="Highlight Overlay" ToolTip="Highlight Overlay" IsChecked="{Binding Capture.SelectedColorCluster.IsActive}" Content="Highlight Overlay" Foreground="#aaa" FontSize="10" Margin="0,0,0,8"/>
                                            
                                            <!-- Colors -->
                                            <TextBlock Text="Colors (Use Eyedropper 💧 to sample)" Foreground="#aaa" FontSize="9" Margin="0,4,0,4"/>
                                            <ListBox ItemsSource="{Binding Capture.SelectedColorCluster.Colors}" Background="#222" BorderBrush="#444" BorderThickness="1" MinHeight="60" MaxHeight="100" AutomationProperties.Name="Cluster Colors List" ToolTip="List of colors in the selected cluster">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,1">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Border Width="12" Height="12" Background="{Binding}" CornerRadius="2" Margin="0,0,8,0" BorderBrush="#444" BorderThickness="1"/>
                                                            <TextBlock Grid.Column="1" Text="{Binding}" Foreground="#ccc" FontSize="10" VerticalAlignment="Center"/>
                                                            <Button Grid.Column="2" Content="✕" FontSize="8" Padding="4,0" Background="Transparent" Foreground="#c0392b"
                                                                    AutomationProperties.Name="Remove Color from Cluster" ToolTip="Remove Color from Cluster"
                                                                    Command="{Binding DataContext.Capture.RemoveColorFromClusterCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                    CommandParameter="{Binding}"/>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Grid>
                            </TabItem>
                            <TabItem Header="🌳 UIA TREE" AutomationProperties.Name="UI Automation Tree" ToolTip="Target Window UI Automation Elements Tree">
                                <TreeView ItemsSource="{Binding AutomationTree.RootNodes}" Background="#151515" BorderThickness="0" SelectedItemChanged="AutomationTree_SelectedItemChanged" AutomationProperties.Name="UI Automation Elements Tree" ToolTip="Tree view of UI Automation elements">
                                    <TreeView.ItemTemplate>
                                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                            <TextBlock Text="{Binding Name}" FontSize="10" Foreground="#aaa">
                                                <TextBlock.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="Direct Click (Sidecar)" 
                                                                  AutomationProperties.Name="Direct Click via Sidecar" ToolTip="Execute a direct click using the Sidecar API"
                                                                  Command="{Binding DataContext.AutomationTree.ClickNodeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                  CommandParameter="{Binding}"/>
                                                    </ContextMenu>
                                                </TextBlock.ContextMenu>
                                            </TextBlock>
                                        </HierarchicalDataTemplate>
                                    </TreeView.ItemTemplate>
                                </TreeView>
                            </TabItem>
                            <TabItem Header="⚙️ SIDECAR" AutomationProperties.Name="Sidecar Terminal" ToolTip="Python Sidecar Execution Logs and Control">
                                <Grid Margin="10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <Button Content="RESTART BRAIN" Command="{Binding Sidecar.RestartSidecarCommand}" 
                                                Background="#c0392b" Foreground="White" FontSize="10" FontWeight="Bold"
                                                AutomationProperties.Name="Restart Sidecar" ToolTip="Restart Sidecar"/>
                                        <Button Content="Clear Logs" Command="{Binding Sidecar.ClearLogsCommand}" Margin="10,0,0,0" FontSize="10"
                                                AutomationProperties.Name="Clear Logs" ToolTip="Clear Logs"/>
                                    </StackPanel>
                                    <TextBox Grid.Row="1" Text="{Binding Sidecar.LogsText, Mode=OneWay}" 
                                             IsReadOnly="True" Background="#050505" Foreground="#f39c12" 
                                             FontSize="9" FontFamily="Consolas" BorderThickness="0"
                                             TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                             TextChanged="Terminal_TextChanged"
                                             AutomationProperties.Name="Sidecar Logs" ToolTip="Sidecar Logs"/>
                                    <TextBlock Grid.Row="2" Text="{Binding Sidecar.StatusText}" 
                                               FontSize="9" Foreground="#858585" Margin="0,5,0,0"/>
                                </Grid>
                            </TabItem>
                        </TabControl>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- 3. TERMINAL -->
        <GridSplitter Grid.Row="2" Height="2" HorizontalAlignment="Stretch" Background="#222" AutomationProperties.Name="Main Workspace and Terminal Splitter" ToolTip="Resize Main Workspace and System Terminal" />
        <Border Grid.Row="3" Background="#0a0a0a" Padding="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="SYSTEM TERMINAL" Style="{StaticResource StudioHeader}"/>
                <TextBox Grid.Row="1" Text="{Binding ScriptEditor.LogsText, Mode=OneWay}" 
                         IsReadOnly="True" Background="Transparent" BorderThickness="0" 
                         Foreground="#00FF00" FontFamily="Consolas" FontSize="11"
                         TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                         TextChanged="Terminal_TextChanged"
                         AutomationProperties.Name="System Terminal Logs" ToolTip="System Terminal Logs"/>
            </Grid>
        </Border>
    </Grid>
</Window>
