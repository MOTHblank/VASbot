<Window x:Class="VASbot.Gui.UI.Views.LiveMirrorOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
        Title="Live Overlay Mirror"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">
    <Grid Background="Transparent">
        <skia:SKElement x:Name="SkiaElement"
                        AutomationProperties.Name="Live Overlay Mirror Canvas"
                        ToolTip="Live Overlay Mirror Canvas"
                        PaintSurface="SkiaElement_PaintSurface"
                        MouseDown="SkiaElement_MouseDown"
                        MouseMove="SkiaElement_MouseMove"
                        MouseUp="SkiaElement_MouseUp"
                        Cursor="Cross"/>
    </Grid>
</Window>
